<?xml version="1.0" encoding="UTF-8"?>
<!--
  STDIO MCP Server 专用 logback 配置。
  核心约束：stdout 是 MCP JSON-RPC 通信通道，任何日志/输出都绝对不能写到 stdout，
  否则 client 会把日志行当 JSON 解析 → MismatchedInputException / 工具调用失败。
  因此所有 console 输出强制重定向到 stderr。
-->
<configuration>
    <!-- 显式覆盖 Spring Boot 的 CONSOLE appender：输出流固定为 System.err -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <target>System.err</target>
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>
</configuration>
